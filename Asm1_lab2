; задание 2.3
.486
.model flat, stdcall
option casemap:none

include \masm32\include\masm32.inc
include \masm32\include\kernel32.inc
includelib \masm32\lib\masm32.lib
includelib \masm32\lib\kernel32.lib

.data
    a dd ?
    b dd ?
    result dd ?
    buf db 64 dup(0)

.code
start:

    print chr$("Enter a: ")
    call atodw
    mov a, eax

    print chr$("Enter b: ")
    call atodw
    mov b, eax

    ; a / b
    mov eax, a
    cdq
    idiv b        ; eax = a/b

    mov ebx, eax  ; сохранить частное

    ; 3*(a-b)
    mov eax, a
    sub eax, b
    imul eax, 3

    add eax, ebx
    mov result, eax

    print chr$("Result = ")
    mov eax, result
    call dwtoa
    print eax

    exit
end start

